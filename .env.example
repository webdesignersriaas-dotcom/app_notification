PORT=3201
APP_NOTIFICATION_TOKEN=replace_with_strong_token

ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key

# Optional worker. If false, call POST /api/v1/reminders/run from Render Cron/GitHub Actions/etc.
RUN_REMINDER_WORKER=false
REMINDER_WORKER_INTERVAL_MS=900000
REMINDER_BEFORE_MINUTES=120
REMINDER_LOOKAHEAD_MINUTES=15
